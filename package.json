{
  "name": "webtop-scraper",
  "version": "1.0.0",
  "description": "Playwright scraper for webtop.co.il — used by n8n Execute Command node",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "scrape": "node webtop_scrape.mjs",
    "install-browsers": "npx playwright install chromium",
    "install-browsers-deps": "npx playwright install-deps chromium"
  },
  "dependencies": {
    "express": "^4.21.0",
    "playwright": "^1.44.0"
  }
}

# Webtop credentials — copy to .env and fill in
WEBTOP_USER=your_username_here
WEBTOP_PASS=your_password_here

# Optional scraper settings
WEBTOP_HEADLESS=true                     # set to false to watch the browser during debug
WEBTOP_SESSION=.webtop_session.json      # session cache path (avoids re-login every run)

# Server settings
PORT=3001
PUSH_SECRET=webtop2026                   # shared secret between home machine + VPS

# Telegram (get chat ID by messaging @WebtopKids_Bot then calling /getUpdates)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── VPS / server mode ───────────────────────────────────────────────────────
# USE_LOCAL_SCRAPER=true   → VPS runs scraper (often BLOCKED by school portal!)
# USE_LOCAL_SCRAPER=false  → VPS waits for push from home (RECOMMENDED when blocked)
USE_LOCAL_SCRAPER=false

# ── Home machine daemon (push_loop.mjs) ─────────────────────────────────────
# REQUIRED when USE_LOCAL_SCRAPER=false — run: node push_loop.mjs
VPS_URL=http://76.13.8.113:3001
SCRAPE_INTERVAL=15                       # minutes between pushes
POLL_INTERVAL=30                         # seconds between trigger polls

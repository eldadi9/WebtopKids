# Webtop credentials — copy to .env and fill in
WEBTOP_USER=your_username_here
WEBTOP_PASS=your_password_here

# Optional scraper settings
WEBTOP_HEADLESS=true                     # false = תמיד חלון כרום (גם push_loop). ברירת מחדל true = רקע
# WEBTOP_RENEW_HEADED=true               # רק אם חידוש סשן אוטומטי נכשל ב-headless — פותח חלון זמני
WEBTOP_SESSION=.webtop_session.json      # session cache path (avoids re-login every run)
# Python fetcher (push_loop): logs in via API each run — no browser/CAPTCHA on pull
# USE_API_FETCHER=false                  # force Playwright scraper instead of webtop_api_fetch.py
# WEBTOP_API_LOGIN=false                 # use session file only (no LoginByUserNameAndPassword)
# WEBTOP_SESSION_FALLBACK=false        # strict: never use .webtop_session.json after failed API login
# WEBTOP_RECAPTCHA_RESPONSE=           # optional token from 2captcha etc. if server requires it on REST login
# WEBTOP_SKIP_TOKEN_VALIDATE=true      # debug: skip server check of session file token
# WEBTOP_FORCE_KEEPALIVE=true            # run browser keep-alive even when Python API fetcher exists
# WEBTOP_BASE=https://webtopserver.smartschool.co.il
# WEBTOP_DATA=+Aabe7FAdVluG6Lu+0ibrA==   # if API login fails, copy "Data" from browser devtools Network → login request

# Server settings
PORT=3001
PUSH_SECRET=webtop2026                   # shared secret between home machine + VPS

# Telegram (get chat ID by messaging @WebtopKids_Bot then calling /getUpdates)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# WEBTOP_TELEGRAM_MODE=session          # session=רק "סשן פג" מדולל | off=בלי בוט | all=גם כשלים זמניים
# SESSION_TELEGRAM_COOLDOWN_MS=86400000 # מרווח מינימום בין 2 התראות סשן (מ"ש), ברירת מחדל 24 שעות
# PROACTIVE_TOKEN_REFRESH_MINUTES=180   # כל כמה דקות ניסיון רענון טוקן בשקט (ללא Chrome)
# PROACTIVE_TOKEN_REFRESH=false         # לכבות רענון רקע

# ── VPS / server mode ───────────────────────────────────────────────────────
# USE_LOCAL_SCRAPER=true   → VPS runs scraper (often BLOCKED by school portal!)
# USE_LOCAL_SCRAPER=false  → VPS waits for push from home (RECOMMENDED when blocked)
USE_LOCAL_SCRAPER=false

# אחרי כמה דק׳ בלי עדכון מטמון להציג "נתונים ישנים" (ברירת מחדל 45)
# DATA_STALE_AFTER_MINUTES=45

# ── Home machine daemon (push_loop.mjs) ─────────────────────────────────────
# REQUIRED when USE_LOCAL_SCRAPER=false — run: node push_loop.mjs
VPS_URL=http://76.13.8.113:3001
SCRAPE_INTERVAL=15                       # minutes between pushes
POLL_INTERVAL=30                         # seconds between trigger polls
# PUSH_RETRY_FOREVER=false               # limit retries (default: infinite backoff until success)
# RETRY_MAX_DELAY=600                    # max seconds between scrape retries
# PUSH_HTTP_RETRIES=6                    # VPS push attempts per cycle
# COOKIE_WAIT_ITERATIONS=2880            # how long to wait for session cookie (× COOKIE_POLL_MS)
# SCRAPER_TIMEOUT_MS=600000              # kill hung scraper after N ms (0 = disable; default 10 min)
# SCRAPER_KILL_GRACE_MS=8000             # after SIGTERM, SIGKILL if still alive (Windows/Unix)
# PUSH_LOOP_HEARTBEAT_MINUTES=60         # log “still alive” every N min (0 = off)
# PUSH_LOOP_LOG_FILE=push_loop_run.log    # append every log line (immediate; default file name)
# PUSH_LOOP_LOG_DISABLE=true             # no log file
